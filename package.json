{
  "name": "graduate-kanban",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "apps:build": "vite build && node scripts/build-apps-script.mjs",
    "apps:create": "npm run apps:build && clasp create --type standalone --title \"Graduate Kanban\" --rootDir apps-script",
    "apps:push": "npm run apps:build && clasp push -f",
    "apps:deploy": "clasp deploy --description \"Graduate Kanban web app\""
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "vite": "^5.0.0"
  }
}
